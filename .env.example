# Postgres
POSTGRES_USER=bsm
POSTGRES_PASSWORD=changeme
POSTGRES_DB=bsm

# Backend
JWT_SECRET=changeme-long-random-string
ADMIN_USERNAME=admin
# bcrypt hash, e.g. via: node -e "console.log(require('bcryptjs').hashSync('yourpassword', 10))"
# IMPORTANT: double every literal `$` as `$$` here, or docker compose will treat
# segments like `$2a` / `$10` as (undefined, blank) variable references and corrupt the hash.
ADMIN_PASSWORD_HASH=
EMAILJS_SERVICE_ID=service_xxxxxxx
EMAILJS_PUBLIC_KEY=your_public_key
EMAILJS_PRIVATE_KEY=your_private_key
EMAILJS_TEMPLATE_ID_CONTACT=template_xxxxxxx
EMAILJS_TEMPLATE_ID_ORDER=template_xxxxxxx
CORS_ORIGINS=

# MinIO (media storage)
MINIO_ROOT_USER=bsm-media
MINIO_ROOT_PASSWORD=changeme-long-random-string
MINIO_BUCKET=bsm-media

# Image tags (set by CI on deploy; leave unset for local `docker compose up --build`)
BACKEND_IMAGE=
FRONTEND_IMAGE=
FRONTEND_PORT=8080
