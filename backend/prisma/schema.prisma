generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ---------- Committees / Bureau ----------

model Committee {
  id          Int      @id @default(autoincrement())
  name        String
  description String
  icon        String
  email       String
  members     String[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("committees")
}

model KeyRole {
  id        Int      @id @default(autoincrement())
  title     String
  name      String
  icon      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("key_roles")
}

// ---------- History ----------

model HistoryEvent {
  id          Int      @id @default(autoincrement())
  year        Int
  title       String
  description String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("history_events")
}

// ---------- Planning / Matches ----------

model Match {
  id            Int      @id @default(autoincrement())
  date          DateTime @db.Date
  team          String
  group         String
  isDomicile    Boolean
  timeStart     String
  timeMeetup    String?
  opponent      String?
  location      String?
  boardOfficial String[]
  referees      String[]
  bar           String?
  result        Int[]
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@unique([date, team], name: "date_team_unique")
  @@map("matches")
}

// ---------- News ----------

model NewsArticle {
  id        Int      @id @default(autoincrement())
  title     String
  excerpt   String
  content   String   @db.Text
  date      DateTime @db.Date
  image     String
  category  String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("news_articles")
}

// ---------- Shop / Products ----------

model Product {
  id          Int              @id @default(autoincrement())
  name        String
  category    String
  imageFolder String
  description String
  variants    ProductVariant[]
  flocking    Flocking?
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt

  @@map("products")
}

model ProductVariant {
  id        Int     @id @default(autoincrement())
  size      String?
  color     String?
  price     Decimal @db.Decimal(10, 2)
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)
  productId Int

  @@map("product_variants")
}

model Flocking {
  id        Int     @id @default(autoincrement())
  price     Decimal @db.Decimal(10, 2)
  maxSize   Int
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)
  productId Int     @unique

  @@map("flockings")
}

// ---------- Season Events ----------

model SeasonEvent {
  id        Int      @id @default(autoincrement())
  name      String
  day       String
  month     String
  year      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("season_events")
}

// ---------- Teams ----------

enum TeamCategory {
  men
  women
  pleasure
}

model Team {
  id        Int          @id @default(autoincrement())
  name      String
  image     String
  season    String
  category  TeamCategory
  players   Player[]
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt

  @@map("teams")
}

model Player {
  id       Int    @id @default(autoincrement())
  name     String
  position String
  number   Int
  team     Team   @relation(fields: [teamId], references: [id], onDelete: Cascade)
  teamId   Int

  @@map("players")
}

// ---------- Training Schedules ----------

model WeekSchedule {
  id        Int           @id @default(autoincrement())
  name      String
  period    String?
  days      DaySchedule[]
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt

  @@map("week_schedules")
}

model DaySchedule {
  id             Int               @id @default(autoincrement())
  date           String
  sessions       TrainingSession[]
  weekSchedule   WeekSchedule      @relation(fields: [weekScheduleId], references: [id], onDelete: Cascade)
  weekScheduleId Int

  @@map("day_schedules")
}

model TrainingSession {
  id            Int         @id @default(autoincrement())
  time          String
  groups        String[]
  location      String
  trainer       String
  notes         String?
  daySchedule   DaySchedule @relation(fields: [dayScheduleId], references: [id], onDelete: Cascade)
  dayScheduleId Int

  @@map("training_sessions")
}
